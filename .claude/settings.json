{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "Skill",
      "ToolSearch",
      "WebFetch",
      "WebSearch"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Use the Skill tool to invoke the 'code-review' skill — it runs as a pre-commit check by default and will review the staged changes. After it completes: if critical issues were found that should block the commit, output {\"continue\": false, \"stopReason\": \"Pre-commit review blocked: <summary of issues>\"}. Otherwise output {\"continue\": true, \"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": \"Pre-commit code review passed. <one-line summary>\"}}",
            "if": "Bash(git commit*)",
            "timeout": 120,
            "statusMessage": "Running pre-commit code review..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/evanhastings/.claude/hooks/claudetop-session-end.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/claudetop.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "high",
  "tui": "default",
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true
}
